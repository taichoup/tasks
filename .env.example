# Frontend — required at build time
VITE_API_URL=https://<api-gateway-id>.execute-api.<region>.amazonaws.com/<stage>/tasks

# Lambda — set these as environment variables on each Lambda function in AWS
TASKS_TABLE_NAME=tasks
EMAIL_FROM=sender@example.com
EMAIL_TO=recipient@example.com
# DIGEST_MAX_TASKS=10  # optional, defaults to 10
