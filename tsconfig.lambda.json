{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "esnext.intl"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/lambda-ts",
    "rootDir": "backend",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true
  },
  "include": ["backend"],
  "exclude": ["backend/**/*.test.ts"]
}
